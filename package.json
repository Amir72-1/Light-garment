{
  "name": "light-garment-erp",
  "version": "1.0.0",
  "description": "Garment ERP web application for Light Garment Manufacturing PLC.",
  "type": "module",
  "main": "dist/server/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch src/server/server.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "npm run db:generate && tsc -p tsconfig.server.json && vite build",
    "start": "node dist/server/server.js",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "preview": "vite preview --host 0.0.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Amir72-1/Light-garment.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Amir72-1/Light-garment/issues"
  },
  "homepage": "https://github.com/Amir72-1/Light-garment#readme",
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-query": "^5.101.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.21.0",
    "multer": "^2.2.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  }
}
